APP_NAME=Intellexa Core Chat
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Comma-separated frontend origins allowed by CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
FORCE_REFRAME_DEBUG=false

# Together AI (for embeddings - FREE TIER)
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

HF_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

SUPABASE_URL=
SUPABASE_KEY=  # Anon key (for client-side operations)
SUPABASE_SERVICE_ROLE_KEY=  # Service role key (for backend - bypasses RLS)

# Supabase Storage Bucket for user uploads
SUPABASE_STORAGE_BUCKET=user-uploads

# Memory System Settings
MAX_FILE_SIZE_MB=50
EMBEDDING_DIMENSION=768
CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

SERPAPI_API_KEY=
MOCK_USER_ID=demo_user
