# Clerk Authentication (REQUIRED)
# Get your publishable key from https://dashboard.clerk.com/
# The key should start with 'pk_test_' for development or 'pk_live_' for production
# IMPORTANT: Make sure to copy the ENTIRE key including all characters after the prefix
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_complete_clerk_publishable_key_here

# Backend API URL
# For local development: http://localhost:8000/api
# For production (Vercel -> Railway): https://your-railway-app.up.railway.app/api
VITE_API_BASE_URL=http://localhost:8000/api

# Clerk Token Template (optional - only needed if using custom JWT templates)
VITE_CLERK_TOKEN_TEMPLATE=

# Supabase Configuration (for chat history persistence)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==============================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ==============================================
# 1. Go to your Vercel project settings -> Environment Variables
# 2. Add ALL the above variables with their correct values
# 3. Make sure VITE_CLERK_PUBLISHABLE_KEY is the COMPLETE key (not truncated)
# 4. Set VITE_API_BASE_URL to your Railway backend URL
# 5. Redeploy after adding/updating environment variables
