{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd server && python -m app.main",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120
  }
}
